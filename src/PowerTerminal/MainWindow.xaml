<Window x:Class="PowerTerminal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PowerTerminal.ViewModels"
        xmlns:views="clr-namespace:PowerTerminal.Views"
        mc:Ignorable="d"
        Title="PowerTerminal"
        Height="800" Width="1400"
        MinHeight="500" MinWidth="800"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">

  <WindowChrome.WindowChrome>
    <WindowChrome CaptionHeight="44"
                  GlassFrameThickness="0"
                  CornerRadius="0"
                  ResizeBorderThickness="6" />
  </WindowChrome.WindowChrome>

  <!-- Outer border: 1 px subtle gray outline + 8 px rounded corners -->
  <Border BorderBrush="#3b3b3c"
          BorderThickness="1"
          CornerRadius="8"
          Background="{StaticResource BackgroundBrush}"
          ClipToBounds="True">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="34" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- ════════════ CUSTOM TITLE BAR ════════════ -->
      <Border Grid.Row="0"
              BorderBrush="#3b3b3c"
              BorderThickness="0,0,0,1"
              CornerRadius="7,7,0,0"
              Background="{StaticResource TitleBarBrush}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <!-- Logo: image + app name -->
          <StackPanel Grid.Column="0"
                      Orientation="Horizontal"
                      VerticalAlignment="Center"
                      Margin="8,0,6,0">
            <Image Source="Images/powerterminal.png"
                   Width="24" Height="24"
                   VerticalAlignment="Center"
                   Margin="0,0,6,0" />
            <TextBlock Text="PowerTerminal"
                       Foreground="{StaticResource AccentBrush}"
                       FontSize="13"
                       FontWeight="Bold"
                       VerticalAlignment="Center" />
          </StackPanel>

          <!-- Centre: tab strip + "+" new connection button -->
          <DockPanel Grid.Column="1"
                     LastChildFill="False"
                     VerticalAlignment="Stretch"
                     WindowChrome.IsHitTestVisibleInChrome="True">

            <!-- Terminal tab headers -->
            <ListBox DockPanel.Dock="Left"
                     ItemsSource="{Binding TerminalTabs}"
                     SelectedItem="{Binding ActiveTerminalTab, Mode=TwoWay}"
                     Style="{StaticResource TabStripListBox}"
                     WindowChrome.IsHitTestVisibleInChrome="True">
              <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource TabStripItem}" />
              </ListBox.ItemContainerStyle>
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid MinWidth="100" MaxWidth="200">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Custom logo image (when set) -->
                    <Image Grid.Column="0"
                           Source="{Binding LogoPath, Converter={StaticResource StringToImageConverter}}"
                           Width="16" Height="16"
                           Margin="0,0,6,0"
                           VerticalAlignment="Center"
                           Visibility="{Binding LogoPath, Converter={StaticResource NullOrEmptyToVisConverter}}" />

                    <!-- Default >_ icon (when no logo set) -->
                    <TextBlock Grid.Column="0"
                               Text=">_"
                               FontFamily="Cascadia Code, Consolas, Courier New"
                               FontSize="11"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,0,6,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding LogoPath, Converter={StaticResource NullOrEmptyToVisInvertConverter}}" />

                    <!-- Tab name -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding Header}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               FontSize="12" />

                    <!-- Close ✕ (visible on hover only) -->
                    <Button x:Name="CloseBtn"
                            Grid.Column="2"
                            Content="✕"
                            Style="{StaticResource TabCloseButton}"
                            Tag="{Binding}"
                            Click="CloseTab_Click"
                            Margin="6,0,0,0"
                            Visibility="Hidden"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            ToolTip="Close tab" />
                  </Grid>
                  <DataTemplate.Triggers>
                    <DataTrigger Value="True">
                      <DataTrigger.Binding>
                        <Binding RelativeSource="{RelativeSource AncestorType=ListBoxItem}"
                                 Path="IsMouseOver" />
                      </DataTrigger.Binding>
                      <Setter TargetName="CloseBtn" Property="Visibility" Value="Visible" />
                    </DataTrigger>
                  </DataTemplate.Triggers>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <!-- "+" button + dropdown popup -->
            <Grid DockPanel.Dock="Left"
                  VerticalAlignment="Center"
                  Margin="4,0,0,0">
              <Button x:Name="ConnectBtn"
                      Style="{StaticResource TitleBarButton}"
                      Click="ConnectBtn_Click"
                      WindowChrome.IsHitTestVisibleInChrome="True"
                      Padding="8,6"
                      ToolTip="Open a connection">
                <!-- White "+" new-tab icon -->
                <TextBlock Text="+"
                           FontSize="18"
                           FontWeight="bold"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,-1,0,0" />
              </Button>
              <Popup x:Name="ConnectPopup"
                     Placement="Bottom"
                     PlacementTarget="{Binding ElementName=ConnectBtn}"
                     StaysOpen="False">
                <Border Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        MinWidth="240"
                        Padding="0,4">
                  <StackPanel>
                    <ItemsControl ItemsSource="{Binding ConnectionManager.Connections}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Button Tag="{Binding}"
                                  Click="ConnectItem_Click"
                                  Style="{StaticResource ConnectPopupItem}">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Text=">_"
                                         FontFamily="Cascadia Code, Consolas, Courier New"
                                         FontSize="11"
                                         Foreground="{StaticResource AccentBrush}"
                                         Margin="0,0,10,0"
                                         VerticalAlignment="Center" />
                              <TextBlock Text="{Binding Name}"
                                         VerticalAlignment="Center" />
                            </StackPanel>
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!-- Placeholder when no connections configured -->
                    <TextBlock Text="No connections configured."
                               Foreground="{StaticResource ForegroundDimBrush}"
                               FontSize="11"
                               Padding="14,6"
                               Visibility="{Binding ConnectionManager.Connections.Count,
                                                   Converter={StaticResource ZeroCountToVisConverter}}" />
                    <Separator Margin="0,4" />
                    <Button Content="Manage Connections…"
                            Style="{StaticResource ConnectPopupItem}"
                            Click="ManageConnections_Click" />
                  </StackPanel>
                </Border>
              </Popup>
            </Grid>
          </DockPanel>

          <!-- Right: window controls -->
          <StackPanel Grid.Column="2"
                      Orientation="Horizontal"
                      VerticalAlignment="Stretch"
                      WindowChrome.IsHitTestVisibleInChrome="True">


            <!-- Minimize -->
            <Button Style="{StaticResource WinControlButton}"
                    Click="Minimize_Click"
                    ToolTip="Minimize">
              <TextBlock Text="&#xE921;"
                         FontFamily="Segoe MDL2 Assets"
                         FontSize="10" />
            </Button>

            <!-- Maximize / Restore -->
            <Button x:Name="MaxRestoreBtn"
                    Style="{StaticResource WinControlButton}"
                    Click="MaximizeRestore_Click"
                    ToolTip="Maximize">
              <TextBlock x:Name="MaxRestoreIcon"
                         Text="&#xE922;"
                         FontFamily="Segoe MDL2 Assets"
                         FontSize="10" />
            </Button>

            <!-- Close -->
            <Button Style="{StaticResource WinCloseButton}"
                    Click="CloseWindow_Click"
                    ToolTip="Close">
              <TextBlock Text="&#xE8BB;"
                         FontFamily="Segoe MDL2 Assets"
                         FontSize="11" />
            </Button>
          </StackPanel>
        </Grid>
      </Border>
      <!-- ════════════ CONTENT AREA ════════════ -->
      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <!-- Terminal -->
          <ColumnDefinition Width="*" MinWidth="200" />
          <!-- Splitter -->
          <ColumnDefinition Width="Auto" />
          <!-- Right panel — width managed from code-behind (0 when closed, 30% when open) -->
          <ColumnDefinition x:Name="PanelColumn" Width="0" MinWidth="0" />
          <!-- Sidebar icon strip — same width as the title bar height (34 px) -->
          <ColumnDefinition Width="34" />
        </Grid.ColumnDefinitions>

        <!-- ── Terminal area ── -->
        <Grid Grid.Column="0">
          <!-- Welcome placeholder -->
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Visibility="{Binding ActiveTerminalTab,
                                    Converter={StaticResource NullToVisInvertConverter}}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,14">
              <Image Source="Images/powerterminal.png"
                     Width="32" Height="32"
                     VerticalAlignment="Center"
                     Margin="0,4,8,0" />
              <TextBlock Text="PowerTerminal"
                         FontSize="28" FontWeight="Bold"
                         Foreground="{StaticResource AccentBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="Click + to open a connection"
                       Foreground="{StaticResource ForegroundDimBrush}"
                       FontSize="14"
                       HorizontalAlignment="Center" />
          </StackPanel>

          <ItemsControl ItemsSource="{Binding TerminalTabs}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><Grid /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
              <Style TargetType="ContentPresenter">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="VerticalAlignment"   Value="Stretch"/>
              </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="{x:Type vm:TerminalTabViewModel}">
                <views:TerminalTabView
                  Visibility="{Binding IsActive, Converter={StaticResource BoolToVisConverter}}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Grid>

        <!-- ── Splitter ── -->
        <GridSplitter Grid.Column="1"
                      Width="2"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext"
                      Background="{StaticResource BorderBrush}"/>

        <!-- ── Right panel (Wiki / AI Chat / Explorer / Settings) ── -->
        <Border Grid.Column="2"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1,0,0,0"
                Background="{StaticResource SurfaceBrush}">
          <Grid>
            <!-- Wiki panel -->
            <views:WikiView DataContext="{Binding Wiki}"
                            Visibility="{Binding DataContext.WikiPanelActive,
                                         RelativeSource={RelativeSource AncestorType=Window},
                                         Converter={StaticResource BoolToVisConverter}}"/>
            <!-- AI Chat panel -->
            <views:AiChatView DataContext="{Binding AiChat}"
                              Visibility="{Binding DataContext.AiChatPanelActive,
                                           RelativeSource={RelativeSource AncestorType=Window},
                                           Converter={StaticResource BoolToVisConverter}}"/>
            <!-- Explorer placeholder -->
            <Grid Visibility="{Binding DataContext.ExplorerPanelActive,
                                RelativeSource={RelativeSource AncestorType=Window},
                                Converter={StaticResource BoolToVisConverter}}">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <Border Grid.Row="0"
                      BorderBrush="{StaticResource BorderBrush}"
                      BorderThickness="0,0,0,1"
                      Padding="16,10">
                <TextBlock Text="Explorer"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource ForegroundBrush}"/>
              </Border>
              <StackPanel Grid.Row="1"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                <TextBlock Text="&#xE8B7;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="40"
                           Foreground="{StaticResource ForegroundDimBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                <TextBlock Text="Coming soon"
                           FontSize="13"
                           Foreground="{StaticResource ForegroundDimBrush}"
                           HorizontalAlignment="Center"/>
              </StackPanel>
            </Grid>
            <!-- Settings panel -->
            <views:SettingsPanelView
                        Visibility="{Binding DataContext.SettingsPanelActive,
                                     RelativeSource={RelativeSource AncestorType=Window},
                                     Converter={StaticResource BoolToVisConverter}}"/>
          </Grid>
        </Border>

        <!-- ── Right activity sidebar ── -->
        <Border Grid.Column="3"
                Background="{StaticResource TitleBarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1,0,0,0">
          <StackPanel VerticalAlignment="Top"
                      Margin="0,6,0,0">

            <!-- Wiki -->
            <ToggleButton Style="{StaticResource SidebarButton}"
                          IsChecked="{Binding WikiPanelActive, Mode=OneWay}"
                          Command="{Binding TogglePanelCommand}"
                          CommandParameter="wiki"
                          ToolTip="Wiki"
                          ToolTipService.InitialShowDelay="0">
              <TextBlock Text="&#xE736;"
                         FontFamily="Segoe MDL2 Assets"
                         FontSize="14"
                         Foreground="White"/>
            </ToggleButton>

            <!-- AI Chat -->
            <ToggleButton Style="{StaticResource SidebarButton}"
                          IsChecked="{Binding AiChatPanelActive, Mode=OneWay}"
                          Command="{Binding TogglePanelCommand}"
                          CommandParameter="aichat"
                          ToolTip="AI Chat"
                          ToolTipService.InitialShowDelay="0">
              <TextBlock Text="&#xE8BD;"
                         FontFamily="Segoe MDL2 Assets"
                         FontSize="14"
                         Foreground="White"/>
            </ToggleButton>

            <!-- Explorer -->
            <ToggleButton Style="{StaticResource SidebarButton}"
                          IsChecked="{Binding ExplorerPanelActive, Mode=OneWay}"
                          Command="{Binding TogglePanelCommand}"
                          CommandParameter="explorer"
                          ToolTip="Explorer"
                          ToolTipService.InitialShowDelay="0">
              <TextBlock Text="&#xEC50;"
                         FontFamily="Segoe MDL2 Assets"
                         FontSize="14"
                         Foreground="White"/>
            </ToggleButton>

            <!-- Settings -->
            <ToggleButton Style="{StaticResource SidebarButton}"
                          IsChecked="{Binding SettingsPanelActive, Mode=OneWay}"
                          Command="{Binding TogglePanelCommand}"
                          CommandParameter="settings"
                          ToolTip="Settings"
                          ToolTipService.InitialShowDelay="0">
              <TextBlock Text="&#xE713;"
                         FontFamily="Segoe MDL2 Assets"
                         FontSize="14"
                         Foreground="White"/>
            </ToggleButton>

          </StackPanel>
        </Border>
      </Grid>
    </Grid>
  </Border>
</Window>
