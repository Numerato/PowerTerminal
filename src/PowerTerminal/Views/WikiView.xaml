<UserControl x:Class="PowerTerminal.Views.WikiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PowerTerminal.ViewModels"
             xmlns:models="clr-namespace:PowerTerminal.Models">
    <UserControl.Resources>

        <!-- Text section template -->
        <DataTemplate x:Key="TextSectionTemplate" DataType="{x:Type models:WikiSection}">
            <TextBlock Text="{Binding Content}"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource ForegroundBrush}"
                       FontFamily="Segoe UI, Arial"
                       FontSize="13"
                       Margin="0,0,0,8"/>
        </DataTemplate>

        <!-- Command block template -->
        <DataTemplate x:Key="CommandSectionTemplate" DataType="{x:Type models:WikiSection}">
            <Border Background="#0F0F0F"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Margin="0,0,0,8"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header bar -->
                    <Border Grid.Row="0"
                            Background="{StaticResource SurfaceHighBrush}"
                            CornerRadius="4,4,0,0"
                            Padding="8,4">
                        <DockPanel>
                            <TextBlock Text="{Binding Language}"
                                       Foreground="{StaticResource ForegroundDimBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        DockPanel.Dock="Right">
                                <Button Content="Copy"
                                        Style="{StaticResource FlatButton}"
                                        Tag="{Binding}"
                                        Click="CopyCommand_Click"
                                        FontSize="11"
                                        Padding="8,3"
                                        Margin="0,0,4,0"
                                        ToolTip="Copy command to terminal"/>
                                <Button Content="Copy &amp; Execute"
                                        Style="{StaticResource AccentButton}"
                                        Tag="{Binding}"
                                        Click="ExecuteCommand_Click"
                                        FontSize="11"
                                        Padding="8,3"
                                        ToolTip="Copy command to terminal and press Enter"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Command text -->
                    <TextBox Grid.Row="1"
                             Text="{Binding Content, Mode=OneWay}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#C8E6C9"
                             FontFamily="Cascadia Code, Consolas, Courier New"
                             FontSize="12"
                             Padding="10,8"
                             VerticalScrollBarVisibility="Disabled"/>
                </Grid>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Panel header -->
        <Border Grid.Row="0"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <TextBlock Text="Wiki"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{StaticResource ForegroundBrush}"/>
        </Border>

        <!-- Search bar -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,6,0"
                         ToolTip="Search by title, tags, description or content"
                         KeyDown="SearchBox_KeyDown"/>
                <Button Grid.Column="1"
                        Content="Search"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding SearchCommand}"
                        Margin="0,0,4,0"
                        MinWidth="60"/>
                <Button Grid.Column="2"
                        Content="x"
                        Style="{StaticResource FlatButton}"
                        Command="{Binding ClearSearchCommand}"
                        ToolTip="Clear search"/>
            </Grid>
        </Border>

        <!-- Wiki action buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="8,0,8,6">
            <Button Content="+ New"
                    Style="{StaticResource FlatButton}"
                    Click="NewWiki_Click"
                    Margin="0,0,4,0"/>
            <Button Content="Edit"
                    Style="{StaticResource FlatButton}"
                    Click="EditWiki_Click"
                    Margin="0,0,4,0"
                    IsEnabled="{Binding SelectedEntry, Converter={StaticResource NullToBoolConverter}}"/>
            <Button Content="Delete"
                    Style="{StaticResource FlatButton}"
                    Click="DeleteWiki_Click"
                    IsEnabled="{Binding SelectedEntry, Converter={StaticResource NullToBoolConverter}}"/>
        </StackPanel>

        <!-- Search results list -->
        <Border Grid.Row="3"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,1">
            <ListBox ItemsSource="{Binding SearchResults}"
                     SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                     Background="{StaticResource BackgroundBrush}"
                     BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:WikiEntry}">
                        <Grid Margin="0,2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="{Binding Title}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Row="1"
                                       FontSize="11"
                                       Foreground="{StaticResource ForegroundDimBrush}"
                                       TextTrimming="CharacterEllipsis">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0}  [{1}]">
                                        <Binding Path="Description"/>
                                        <Binding Path="Tags" Converter="{StaticResource ListToStringConverter}"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Article detail viewer -->
        <ScrollViewer Grid.Row="4"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="{StaticResource BackgroundBrush}"
                      Padding="8">
            <StackPanel>
                <!-- Entry header -->
                <TextBlock Text="{Binding SelectedEntry.Title}"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{StaticResource ForegroundBrush}"
                           Margin="0,0,0,4"
                           Visibility="{Binding SelectedEntry, Converter={StaticResource NullToVisConverter}}"/>
                <TextBlock Text="{Binding SelectedEntry.Description}"
                           FontSize="12"
                           Foreground="{StaticResource ForegroundDimBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,4"
                           Visibility="{Binding SelectedEntry, Converter={StaticResource NullToVisConverter}}"/>
                <TextBlock Foreground="{StaticResource AccentBrush}"
                           FontSize="11"
                           Margin="0,0,0,10"
                           Visibility="{Binding SelectedEntry, Converter={StaticResource NullToVisConverter}}">
                    <TextBlock.Text>
                        <Binding Path="SelectedEntry.Tags"
                                 Converter="{StaticResource ListToStringConverter}"
                                 StringFormat="Tags: {0}"/>
                    </TextBlock.Text>
                </TextBlock>
                <Separator Visibility="{Binding SelectedEntry, Converter={StaticResource NullToVisConverter}}"/>

                <!-- Sections -->
                <ItemsControl ItemsSource="{Binding SelectedEntry.Sections}"
                              Margin="0,8,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:WikiSection}">
                            <ContentControl Content="{Binding}"
                                            Loaded="SectionControl_Loaded"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Placeholder when nothing selected -->
                <TextBlock Text="Select a wiki entry from the list above to view its content."
                           Foreground="{StaticResource ForegroundDimBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,40,0,0"
                           Visibility="{Binding SelectedEntry, Converter={StaticResource NullToVisInvertConverter}}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
