<Window x:Class="PowerTerminal.Views.PasswordPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SSH Authentication"
        Width="400" SizeToContent="Height"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Icon + title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock Text="🔒"
                       FontSize="20"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>
            <TextBlock Text="Authentication Required"
                       FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Server prompt (e.g. "geertm@server's password:") -->
        <TextBlock Grid.Row="1"
                   x:Name="PromptText"
                   FontSize="12"
                   Foreground="{StaticResource ForegroundDimBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <!-- Password entry -->
        <PasswordBox Grid.Row="2"
                     x:Name="PasswordInput"
                     KeyDown="PasswordInput_KeyDown"
                     Margin="0,0,0,16"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Connect"
                    Style="{StaticResource AccentButton}"
                    Click="Connect_Click"
                    Margin="0,0,8,0"
                    MinWidth="80"
                    IsDefault="True"/>
            <Button Content="Cancel"
                    Style="{StaticResource FlatButton}"
                    Click="Cancel_Click"
                    MinWidth="80"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
