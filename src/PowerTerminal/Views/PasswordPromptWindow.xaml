<Window x:Class="PowerTerminal.Views.PasswordPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="400" SizeToContent="Height"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border BorderBrush="#777777"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource BackgroundBrush}"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0"
                  Background="{StaticResource TitleBarBrush}"
                  MouseLeftButtonDown="TitleBar_MouseDown">
                <TextBlock Text="SSH Authentication"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Foreground="{StaticResource ForegroundDimBrush}"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"/>
                <Button Style="{StaticResource DialogCloseButton}"
                        HorizontalAlignment="Right"
                        Click="Cancel_Click">
                    <TextBlock Text="&#xE8BB;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="10"/>
                </Button>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20,16,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Icon + title -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                    <TextBlock Text="🔒"
                               FontSize="18"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBlock Text="Authentication Required"
                               FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Server prompt text -->
                <TextBlock Grid.Row="1"
                           x:Name="PromptText"
                           FontSize="12"
                           Foreground="{StaticResource ForegroundDimBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"/>

                <!-- Password entry -->
                <PasswordBox Grid.Row="2"
                             x:Name="PasswordInput"
                             KeyDown="PasswordInput_KeyDown"
                             Margin="0,0,0,16"/>

                <!-- Buttons -->
                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Connect"
                            Style="{StaticResource AccentButton}"
                            Click="Connect_Click"
                            Margin="0,0,8,0"
                            MinWidth="80"
                            IsDefault="True"/>
                    <Button Content="Cancel"
                            Style="{StaticResource FlatButton}"
                            Click="Cancel_Click"
                            MinWidth="80"
                            IsCancel="True"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
