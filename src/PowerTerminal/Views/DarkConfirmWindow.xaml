<Window x:Class="PowerTerminal.Views.DarkConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="360" SizeToContent="Height"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border BorderBrush="#777777"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource BackgroundBrush}"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0"
                  Background="{StaticResource TitleBarBrush}"
                  MouseLeftButtonDown="TitleBar_MouseDown">
                <TextBlock x:Name="TitleText"
                           Text="Confirm"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Foreground="{StaticResource ForegroundDimBrush}"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"/>
                <Button Style="{StaticResource DialogCloseButton}"
                        HorizontalAlignment="Right"
                        Click="No_Click">
                    <TextBlock Text="&#xE8BB;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="10"/>
                </Button>
            </Grid>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="20,16,20,20">
                <TextBlock x:Name="MessageText"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"
                           FontSize="13"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Yes"
                            Style="{StaticResource AccentButton}"
                            Click="Yes_Click"
                            Margin="0,0,8,0"
                            MinWidth="72"
                            IsDefault="True"/>
                    <Button Content="No"
                            Style="{StaticResource FlatButton}"
                            Click="No_Click"
                            MinWidth="72"
                            IsCancel="True"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
