<Window x:Class="PowerTerminal.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="540" Width="560"
        MinHeight="400" MinWidth="450"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="ToolWindow"
        ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Settings"
                   FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- AI Settings -->
                <TextBlock Text="AI Configuration"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="API Base URL:"/>
                    <TextBox Grid.Column="1"
                             x:Name="ApiBaseUrl"
                             ToolTip="OpenAI-compatible endpoint, e.g. https://api.openai.com/v1"/>
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="API Token:"/>
                    <PasswordBox Grid.Column="1" x:Name="ApiToken"/>
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Model:"/>
                    <TextBox Grid.Column="1" x:Name="ModelName"
                             ToolTip="e.g. gpt-4o-mini, gpt-4o, gpt-3.5-turbo"/>
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Temperature:"/>
                    <Slider Grid.Column="1"
                            x:Name="Temperature"
                            Minimum="0" Maximum="2"
                            SmallChange="0.1" LargeChange="0.5"
                            TickFrequency="0.1"
                            Foreground="{StaticResource AccentBrush}"/>
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="System Prompt:"/>
                    <TextBox Grid.Column="1"
                             x:Name="SystemPrompt"
                             AcceptsReturn="True"
                             MinHeight="60"
                             MaxHeight="120"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>
                </Grid>

                <Separator Margin="0,12,0,12"/>

                <!-- Theme settings -->
                <TextBlock Text="Terminal Appearance"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Font Family:"/>
                    <TextBox Grid.Column="1" x:Name="FontFamilyInput"
                             ToolTip="Cascadia Code, Consolas, Courier New"/>
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Font Size:"/>
                    <TextBox Grid.Column="1" x:Name="FontSizeInput"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Save"
                    Style="{StaticResource AccentButton}"
                    Click="Save_Click"
                    Margin="0,0,8,0" MinWidth="80"/>
            <Button Content="Cancel"
                    Style="{StaticResource FlatButton}"
                    Click="Cancel_Click"
                    MinWidth="80"/>
        </StackPanel>
    </Grid>
</Window>
