<UserControl x:Class="PowerTerminal.Views.AiChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:PowerTerminal.Models">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Panel header -->
        <Border Grid.Row="0"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <TextBlock Text="AI Chat"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{StaticResource ForegroundBrush}"/>
        </Border>

        <!-- Message list -->
        <ScrollViewer Grid.Row="1"
                      x:Name="MessagesScroller"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="MessagesList"
                          ItemsSource="{Binding Messages}"
                          Padding="8,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:AiMessage}">
                        <Border Margin="0,0,0,12"
                                Padding="12,8"
                                CornerRadius="6"
                                Background="{Binding Role, Converter={StaticResource RoleToBackgroundConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Text="{Binding Role, Converter={StaticResource RoleToLabelConverter}}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{Binding Role, Converter={StaticResource RoleToForeConverter}}"
                                           Margin="0,0,0,4"/>
                                <TextBox Grid.Row="1"
                                         Text="{Binding Content, Mode=OneWay}"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{StaticResource ForegroundBrush}"
                                         FontFamily="Segoe UI, Arial"
                                         FontSize="13"
                                         Padding="0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
