<Window x:Class="PowerTerminal.Views.WikiEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PowerTerminal.ViewModels"
        xmlns:models="clr-namespace:PowerTerminal.Models"
        Title="Wiki Editor"
        Height="680" Width="900"
        MinHeight="500" MinWidth="700"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="ThreeDBorderWindow"
        ResizeMode="CanResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Wiki Editor"
                   FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <!-- Metadata fields -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Title:"/>
            <TextBox Grid.Column="1"
                     Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"/>
            <Label Grid.Column="3" Content="Tags (csv):"/>
            <TextBox Grid.Column="4"
                     Text="{Binding Tags, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Comma-separated tags, e.g.: linux, networking, docker"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Description:"/>
            <TextBox Grid.Column="1"
                     Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Short summary of this wiki entry"/>
        </Grid>

        <!-- Sections editor -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Section content editor -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="{Binding SelectedSection.Type, StringFormat='Edit {0} section:',
                                  FallbackValue='Select a section to edit'}"
                           Foreground="{StaticResource ForegroundDimBrush}"
                           FontSize="12" Margin="0,0,0,4"/>
                <TextBox Grid.Row="1"
                         Text="{Binding SelectedSection.Content, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding SelectedSection, Converter={StaticResource NullToBoolConverter}}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         FontSize="13"/>
                <TextBlock Grid.Row="2"
                           Text="For command sections: use $variable:Name$ for user prompts, $homefolder$ etc. for machine variables."
                           Foreground="{StaticResource ForegroundDimBrush}"
                           FontSize="10"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>
            </Grid>

            <!-- Section list + controls -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Sections"
                           FontWeight="SemiBold" Margin="0,0,0,4"/>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Sections}"
                         SelectedItem="{Binding SelectedSection, Mode=TwoWay}"
                         Background="{StaticResource SurfaceBrush}"
                         Margin="0,0,0,8">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:WikiSection}">
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Background="{Binding Type, Converter={StaticResource SectionTypeToColorConverter}}"
                                        CornerRadius="2"
                                        Padding="4,1"
                                        Margin="0,0,6,0">
                                    <TextBlock Text="{Binding Type}" FontSize="10"
                                               Foreground="White"/>
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Content}"
                                           MaxWidth="140"
                                           TextTrimming="CharacterEllipsis"
                                           FontSize="11"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <WrapPanel Grid.Row="2">
                    <Button Content="+ Text"    Style="{StaticResource FlatButton}" Command="{Binding AddTextSectionCommand}"    Margin="0,0,4,4" FontSize="11"/>
                    <Button Content="+ Command" Style="{StaticResource FlatButton}" Command="{Binding AddCommandSectionCommand}" Margin="0,0,4,4" FontSize="11"/>
                    <Button Content="Remove"    Style="{StaticResource FlatButton}" Command="{Binding RemoveSectionCommand}"     Margin="0,0,4,4" FontSize="11"/>
                    <Button Content="Up"        Style="{StaticResource FlatButton}" Command="{Binding MoveSectionUpCommand}"     Margin="0,0,4,4" FontSize="11" MinWidth="30"/>
                    <Button Content="Down"      Style="{StaticResource FlatButton}" Command="{Binding MoveSectionDownCommand}"   Margin="0,0,0,4" FontSize="11" MinWidth="36"/>
                </WrapPanel>
            </Grid>
        </Grid>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Save"
                    Style="{StaticResource AccentButton}"
                    Command="{Binding SaveCommand}"
                    Margin="0,0,8,0" MinWidth="80"/>
            <Button Content="Cancel"
                    Style="{StaticResource FlatButton}"
                    Command="{Binding CancelCommand}"
                    MinWidth="80"/>
        </StackPanel>
    </Grid>
</Window>
