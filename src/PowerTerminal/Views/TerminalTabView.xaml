<UserControl x:Class="PowerTerminal.Views.TerminalTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:PowerTerminal.Controls"
             Background="Transparent">

  <Grid Margin="0">
        <ctrl:TerminalControl x:Name="Terminal"
                              VerticalAlignment="Stretch"
                              HorizontalAlignment="Stretch"
                              TerminalFontFamily="{Binding Theme.FontFamily}"
                              TerminalFontSize="{Binding Theme.FontSize}"
                              Padding="{Binding TerminalPadding}"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="Transparent">
          <ctrl:TerminalControl.Resources>
                <Style TargetType="{x:Type ScrollBar}"
                       BasedOn="{StaticResource TerminalScrollBar}"/>
            </ctrl:TerminalControl.Resources>
        </ctrl:TerminalControl>
    </Grid>
</UserControl>
