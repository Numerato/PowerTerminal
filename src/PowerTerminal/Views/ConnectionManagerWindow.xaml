<Window x:Class="PowerTerminal.Views.ConnectionManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PowerTerminal.ViewModels"
        Title="Connection Manager"
        Height="520" Width="700"
        MinHeight="400" MinWidth="500"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="ToolWindow"
        ResizeMode="CanResize">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Connection list -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ListBox Grid.Row="0"
                     ItemsSource="{Binding Connections}"
                     SelectedItem="{Binding Selected, Mode=TwoWay}"
                     Background="{StaticResource SurfaceBrush}"
                     Margin="0,0,0,8">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                            <TextBlock FontSize="11"
                                       Foreground="{StaticResource ForegroundDimBrush}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0}@{1}:{2}">
                                        <Binding Path="Username"/>
                                        <Binding Path="Host"/>
                                        <Binding Path="Port"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel Grid.Row="1" Orientation="Horizontal">
                <Button Content="+ Add"   Style="{StaticResource FlatButton}" Command="{Binding AddCommand}"    Margin="0,0,4,0" MinWidth="55"/>
                <Button Content="Edit"    Style="{StaticResource FlatButton}" Command="{Binding EditCommand}"   Margin="0,0,4,0" MinWidth="55"/>
                <Button Content="Delete"  Style="{StaticResource FlatButton}" Command="{Binding DeleteCommand}" MinWidth="55"/>
            </StackPanel>
        </Grid>

        <Separator Grid.Column="1" Style="{StaticResource {x:Type Separator}}" Width="1" HorizontalAlignment="Center" Margin="0"/>

        <!-- Edit form -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding Editing, Converter={StaticResource NullToStringConverter},
                              ConverterParameter='Edit Connection|Select a connection and click Edit'}"
                       FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <Grid Grid.Row="1"
                  IsEnabled="{Binding Editing, Converter={StaticResource NullToBoolConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Name:"/>
                <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,6"
                         Text="{Binding Editing.Name, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Grid.Row="1" Grid.Column="0" Content="Host / IP:"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,6"
                         Text="{Binding Editing.Host, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Grid.Row="2" Grid.Column="0" Content="Username:"/>
                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,6"
                         Text="{Binding Editing.Username, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Grid.Row="3" Grid.Column="0" Content="Port:"/>
                <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,6"
                         Text="{Binding Editing.Port, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Grid.Row="4" Grid.Column="0" Content="Private Key:"/>
                <Grid Grid.Row="4" Grid.Column="1" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding Editing.PrivateKeyPath, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,4,0"/>
                    <Button Grid.Column="1" Content="Browse"
                            Style="{StaticResource FlatButton}"
                            Click="BrowseKey_Click"
                            Margin="0,0,4,0"/>
                    <Button Grid.Column="2" Content="Clear"
                            Style="{StaticResource FlatButton}"
                            Click="ClearKey_Click"/>
                </Grid>

                <TextBlock Grid.Row="5" Grid.ColumnSpan="2"
                           Text="Leave Private Key empty to authenticate with a password (you will be prompted on connect)."
                           Foreground="{StaticResource ForegroundDimBrush}"
                           FontSize="11"
                           TextWrapping="Wrap"/>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Save"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding SaveCommand}"
                        Margin="0,0,8,0" MinWidth="80"/>
                <Button Content="Cancel"
                        Style="{StaticResource FlatButton}"
                        Command="{Binding CancelCommand}"
                        Margin="0,0,8,0" MinWidth="80"/>
                <Button Content="Connect"
                        Style="{StaticResource AccentButton}"
                        Click="Connect_Click"
                        IsEnabled="{Binding Selected, Converter={StaticResource NullToBoolConverter}}"
                        MinWidth="80"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
