<Window x:Class="PowerTerminal.Views.ConnectionManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PowerTerminal.ViewModels"
        Height="560" Width="720"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border BorderBrush="#777777"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource BackgroundBrush}"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Title bar ── -->
            <Border Grid.Row="0"
                    Background="{StaticResource TitleBarBrush}"
                    BorderBrush="#3b3b3c"
                    BorderThickness="0,0,0,1"
                    CornerRadius="7,7,0,0">
            <Grid MouseLeftButtonDown="TitleBar_MouseDown">
                <TextBlock Text="Connection Manager"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Foreground="{StaticResource ForegroundDimBrush}"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"/>
                <Button Style="{StaticResource DialogCloseButton}"
                        HorizontalAlignment="Right"
                        Click="CloseDialog_Click">
                    <TextBlock Text="&#xE8BB;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="10"/>
                </Button>
            </Grid>
            </Border>

            <!-- ── Body ── -->
            <Grid Grid.Row="1" Margin="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Connection list -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListBox Grid.Row="0"
                             ItemsSource="{Binding Connections}"
                             SelectedItem="{Binding Selected, Mode=TwoWay}"
                             Background="{StaticResource SurfaceBrush}"
                             Margin="0,0,0,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Connection icon -->
                                    <Image Grid.Column="0"
                                           Source="{Binding LogoPath, Converter={StaticResource StringToImageConverter}}"
                                           Width="22" Height="22"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           Visibility="{Binding LogoPath, Converter={StaticResource NullOrEmptyToVisConverter}}"/>
                                    <TextBlock Grid.Column="0"
                                               Text="&#xE8A1;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               Width="22"
                                               TextAlignment="Center"
                                               Foreground="{StaticResource ForegroundDimBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"
                                               Visibility="{Binding LogoPath, Converter={StaticResource NullOrEmptyToVisInvertConverter}}"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock FontSize="11"
                                                   Foreground="{StaticResource ForegroundDimBrush}">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0}@{1}:{2}">
                                                    <Binding Path="Username"/>
                                                    <Binding Path="Host"/>
                                                    <Binding Path="Port"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <Button Content="+ Add"  Style="{StaticResource FlatButton}" Command="{Binding AddCommand}"    Margin="0,0,4,0" MinWidth="55"/>
                        <Button Content="Delete" Style="{StaticResource FlatButton}" Command="{Binding DeleteCommand}" MinWidth="55"/>
                    </StackPanel>
                </Grid>

                <Separator Grid.Column="1" Style="{StaticResource {x:Type Separator}}" Width="1" HorizontalAlignment="Center" Margin="0"/>

                <!-- Edit form -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding Editing, Converter={StaticResource NullToStringConverter},
                                      ConverterParameter='Edit Connection|Select a connection to edit'}"
                               FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <Grid Grid.Row="1"
                          IsEnabled="{Binding Editing, Converter={StaticResource NullToBoolConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Name:"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,6"
                                 Text="{Binding Editing.Name, UpdateSourceTrigger=PropertyChanged}"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="Host / IP:"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,6"
                                 Text="{Binding Editing.Host, UpdateSourceTrigger=PropertyChanged}"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="Username:"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,6"
                                 Text="{Binding Editing.Username, UpdateSourceTrigger=PropertyChanged}"/>

                        <Label Grid.Row="3" Grid.Column="0" Content="Port:"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,6"
                                 Text="{Binding Editing.Port, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- Tab Icon: ComboBox of predefined icons + Browse -->
                        <Label Grid.Row="4" Grid.Column="0" Content="Tab Icon:"
                               VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <Grid Grid.Row="4" Grid.Column="1" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon preview + dropdown -->
                            <ComboBox Grid.Column="0"
                                      x:Name="IconComboBox"
                                      ItemsSource="{Binding IconOptions}"
                                      SelectionChanged="IconComboBox_SelectionChanged"
                                      Background="{StaticResource SurfaceBrush}"
                                      Foreground="{StaticResource ForegroundBrush}"
                                      Margin="0,0,4,0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <Image Source="{Binding Path, Converter={StaticResource StringToImageConverter}}"
                                                   Width="20" Height="20"
                                                   Margin="0,0,8,0"
                                                   Stretch="Uniform"/>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- Browse custom file -->
                            <Button Grid.Column="1" Content="Browse…"
                                    Style="{StaticResource FlatButton}"
                                    Click="BrowseLogo_Click"/>
                        </Grid>

                        <!-- SSH key info -->
                        <TextBlock Grid.Row="5" Grid.ColumnSpan="2"
                                   Text="SSH keys are auto-loaded from the global SSH keys folder (Settings → SSH Keys Folder). A password prompt appears if no matching key is found."
                                   Foreground="{StaticResource ForegroundDimBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                    </Grid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="Save"
                                Style="{StaticResource AccentButton}"
                                Click="Save_Click"
                                IsEnabled="{Binding Editing, Converter={StaticResource NullToBoolConverter}}"
                                Margin="0,0,8,0" MinWidth="80"/>
                        <Button Content="Cancel"
                                Style="{StaticResource FlatButton}"
                                Command="{Binding CancelCommand}"
                                Margin="0,0,8,0" MinWidth="80"/>
                        <Button Content="Connect"
                                Style="{StaticResource AccentButton}"
                                Click="Connect_Click"
                                IsEnabled="{Binding Selected, Converter={StaticResource NullToBoolConverter}}"
                                MinWidth="80"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
