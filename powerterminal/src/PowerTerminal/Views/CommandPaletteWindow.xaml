<Window x:Class="PowerTerminal.Views.CommandPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PowerTerminal.ViewModels"
        Width="660"
        SizeToContent="Height"
        MaxHeight="620"
        Background="Transparent"
        FontFamily="Segoe UI, Arial"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Deactivated="Window_Deactivated"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Border BorderBrush="#666666"
            BorderThickness="1.5"
            CornerRadius="10"
            Background="#1A1A1A"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Search bar ── -->
            <Border Grid.Row="0"
                    Background="#222222"
                    BorderBrush="#2A2A2A"
                    BorderThickness="0,0,0,1"
                    Padding="10,7">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Search input with visible rounded border -->
                    <Border Grid.Column="0"
                            Background="#2C2C2C"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="8,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="🔍"
                                       FontSize="12"
                                       Foreground="#BBBBBB"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBox Grid.Column="1"
                                     x:Name="SearchBox"
                                     Style="{StaticResource PromptTextBox}"
                                     Foreground="#F0F0F0"
                                     Background="Transparent"
                                     CaretBrush="{StaticResource AccentBrush}"
                                     FontSize="14"
                                     BorderThickness="0"
                                     Padding="0,7"
                                     Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </Border>
                    <TextBlock Grid.Column="1"
                               x:Name="ResultCount"
                               FontSize="12"
                               Foreground="#AAAAAA"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                </Grid>
            </Border>

            <!-- ── Category chips ── -->
            <Border Grid.Row="1"
                    Background="#1E1E1E"
                    BorderBrush="#262626"
                    BorderThickness="0,0,0,1"
                    Padding="10,8">
                <ItemsControl x:Name="ChipPanel"
                              ItemsSource="{Binding Tags}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="ChipBorder"
                                    Margin="0,0,6,4"
                                    Padding="9,3"
                                    CornerRadius="10"
                                    BorderThickness="1"
                                    BorderBrush="#333333"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="Chip_Click"
                                    Tag="{Binding}">
                                <TextBlock x:Name="ChipText"
                                           Text="{Binding}"
                                           FontSize="12"
                                           Foreground="#999999"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- ── Results list ── -->
            <ListBox Grid.Row="2"
                     x:Name="ResultsList"
                     ItemsSource="{Binding FilteredCommands}"
                     SelectedItem="{Binding SelectedCommand, Mode=TwoWay}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     MaxHeight="340"
                     Padding="0,4"
                     PreviewMouseLeftButtonUp="ResultsList_Click"
                     SelectionChanged="ResultsList_SelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding"          Value="0"/>
                        <Setter Property="Margin"           Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background"       Value="Transparent"/>
                        <Setter Property="BorderThickness"  Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="3,0,0,0"
                                            Padding="11,9">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background"    Value="#242424"/>
                                            <Setter TargetName="Bd" Property="BorderBrush"   Value="{StaticResource AccentBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background"    Value="#1E1E1E"/>
                                            <Setter TargetName="Bd" Property="BorderBrush"   Value="#444444"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <!-- Title row -->
                                <TextBlock x:Name="TitleText"
                                           Text="{Binding Title}"
                                           FontSize="14"
                                           FontWeight="Medium"
                                           Foreground="#E0E0E0"
                                           Margin="0,0,0,3"
                                           TextTrimming="CharacterEllipsis"/>
                                <!-- Command line (rendered with variable highlighting in code-behind) -->
                                <Border Background="#0D0D0D"
                                        BorderBrush="#2E2E2E"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Padding="7,3"
                                        Margin="0,0,0,4">
                                    <TextBlock x:Name="CmdLine"
                                               FontFamily="Cascadia Code, Consolas, Courier New"
                                               FontSize="12"
                                               Foreground="#7EC8A0"
                                               TextTrimming="CharacterEllipsis"/>
                                </Border>
                                <!-- Description -->
                                <TextBlock Text="{Binding Description}"
                                           FontSize="12"
                                           Foreground="#AAAAAA"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <!-- Tags -->
                            <ItemsControl Grid.Column="1"
                                          ItemsSource="{Binding Tags}"
                                          VerticalAlignment="Top">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="2,0,0,0"
                                                Padding="5,2"
                                                CornerRadius="3"
                                                Background="#252525"
                                                BorderBrush="#2E2E2E"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding}"
                                                       FontSize="11"
                                                       Foreground="#888888"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- ── Detail strip ── -->
            <Border Grid.Row="3"
                    x:Name="DetailStrip"
                    Background="#1E1E1E"
                    BorderBrush="#262626"
                    BorderThickness="0,1,0,0"
                    Padding="14,10"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="COMMAND"
                                   FontSize="11"
                                   Foreground="#777777"
                                   Margin="0,0,0,4"/>
                        <!-- Rich command with variable segments (built in code-behind) -->
                        <Border Background="#15100A"
                                BorderBrush="#E87722"
                                BorderThickness="2,1,1,1"
                                CornerRadius="4"
                                Padding="8,5">
                            <TextBlock x:Name="DetailCmdBlock"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </Border>
                        <StackPanel x:Name="VarLegend"
                                    Orientation="Horizontal"
                                    Margin="0,6,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="DESCRIPTION"
                                   FontSize="11"
                                   Foreground="#777777"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="DetailDescBlock"
                                   FontSize="13"
                                   Foreground="#AAAAAA"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Footer ── -->
            <Border Grid.Row="4"
                    Background="#181818"
                    BorderBrush="#222222"
                    BorderThickness="0,1,0,0"
                    Padding="14,7">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontSize="12" Foreground="#999999" Margin="0,0,16,0">
                        <Run Text="↑↓"/>
                        <Run Text=" navigate" Foreground="#888888"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Foreground="#999999" Margin="0,0,16,0">
                        <Run Text="Enter"/>
                        <Run Text=" insert to terminal" Foreground="#888888"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Foreground="#999999">
                        <Run Text="Esc"/>
                        <Run Text=" close" Foreground="#888888"/>
                    </TextBlock>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>