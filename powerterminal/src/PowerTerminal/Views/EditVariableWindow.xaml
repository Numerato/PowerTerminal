<Window x:Class="PowerTerminal.Views.EditVariableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="400" SizeToContent="Height"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border BorderBrush="#777777"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource BackgroundBrush}"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource TitleBarBrush}"
                    BorderBrush="#3b3b3c"
                    BorderThickness="0,0,0,1"
                    CornerRadius="7,7,0,0">
                <Grid MouseLeftButtonDown="TitleBar_MouseDown">
                    <TextBlock Text="Edit Variable"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Foreground="{StaticResource ForegroundDimBrush}"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0"/>
                    <Button Style="{StaticResource DialogCloseButton}"
                            HorizontalAlignment="Right"
                            Click="Cancel_Click">
                        <TextBlock Text="&#xE8BB;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="20,16,20,20">
                <TextBlock Text="Variable Name"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource ForegroundDimBrush}"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="NameTextBox"
                         Style="{StaticResource PromptTextBox}"
                         Foreground="#7EC8A0"
                         CaretBrush="{StaticResource ForegroundBrush}"
                         Margin="0,0,0,12"/>

                <TextBlock Text="Value"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource ForegroundDimBrush}"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="ValueTextBox"
                         Style="{StaticResource PromptTextBox}"
                         CaretBrush="{StaticResource ForegroundBrush}"
                         Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Save"
                            Style="{StaticResource AccentButton}"
                            Click="Save_Click"
                            Margin="0,0,8,0"
                            MinWidth="72"
                            IsDefault="True"/>
                    <Button Content="Cancel"
                            Style="{StaticResource FlatButton}"
                            Click="Cancel_Click"
                            MinWidth="72"
                            IsCancel="True"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
