<UserControl x:Class="PowerTerminal.Views.PowerEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PowerTerminal.ViewModels"
             xmlns:avalonEdit="clr-namespace:ICSharpCode.AvalonEdit;assembly=ICSharpCode.AvalonEdit"
             Background="#1a1a1a"
             FontFamily="{Binding FontFamily}"
             FontSize="{Binding FontSize}"
             KeyDown="UserControl_KeyDown">

    <UserControl.Resources>
        <!-- Thin rounded thumb shared by both scrollbar orientations -->
        <Style x:Key="EditorScrollThumb" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop"             Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="Thumb" Background="#55FFFFFF" CornerRadius="3" Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Thumb" Property="Background" Value="#99FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Thumb" Property="Background" Value="#BBFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Vertical scrollbar template -->
        <ControlTemplate x:Key="EditorScrollBarV" TargetType="{x:Type ScrollBar}">
            <Grid Background="Transparent" Width="6">
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.Thumb>
                        <Thumb Style="{StaticResource EditorScrollThumb}"/>
                    </Track.Thumb>
                </Track>
            </Grid>
        </ControlTemplate>

        <!-- Horizontal scrollbar template -->
        <ControlTemplate x:Key="EditorScrollBarH" TargetType="{x:Type ScrollBar}">
            <Grid Background="Transparent" Height="6">
                <Track x:Name="PART_Track" IsDirectionReversed="False">
                    <Track.Thumb>
                        <Thumb Style="{StaticResource EditorScrollThumb}"/>
                    </Track.Thumb>
                </Track>
            </Grid>
        </ControlTemplate>

        <!-- Apply thin scrollbars to all ScrollBars inside this editor -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background"            Value="Transparent"/>
            <Setter Property="Opacity"               Value="0.5"/>
            <Setter Property="Template"              Value="{StaticResource EditorScrollBarV}"/>
            <Setter Property="Width"                 Value="6"/>
            <Setter Property="MinWidth"              Value="6"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Template"   Value="{StaticResource EditorScrollBarH}"/>
                    <Setter Property="Width"      Value="Auto"/>
                    <Setter Property="MinWidth"   Value="0"/>
                    <Setter Property="Height"     Value="6"/>
                    <Setter Property="MinHeight"  Value="6"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- Font set here via TextElement so Menu, StatusBar and Editor all inherit the same typeface -->
    <Grid TextElement.FontFamily="{Binding FontFamily}" TextElement.FontSize="{Binding FontSize}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- menu bar (with filename + close) -->
            <RowDefinition Height="Auto"/>  <!-- find/replace panel -->
            <RowDefinition Height="*"/>     <!-- editor -->
            <RowDefinition Height="Auto"/>  <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ── Menu bar + filename + close ─────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource TitleBarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">

                <!-- Close button — far right -->
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource DialogCloseButton}"
                        Command="{Binding CloseCommand}"
                        ToolTip="Close editor">
                    <TextBlock Text="&#xE8BB;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="10"/>
                </Button>

                <!-- Filename — right of menu, fills remaining space -->
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding TitleText}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource ForegroundDimBrush}"
                           Margin="12,0"/>

                <!-- Menu — left side -->
                <Menu Background="Transparent"
                      BorderThickness="0"
                      Padding="4,2"
                      VerticalAlignment="Center">

                    <MenuItem Header="_File">
                        <MenuItem Header="_Save"
                                  Command="{Binding SaveCommand}"
                                  InputGestureText="Ctrl+S"/>
                        <MenuItem Header="Save _As…"
                                  Command="{Binding SaveAsCommand}"/>
                        <Separator/>
                        <MenuItem Header="E_xit"
                                  Command="{Binding CloseCommand}"/>
                    </MenuItem>

                    <MenuItem Header="_Edit">
                        <MenuItem Header="_Undo"
                                  Command="ApplicationCommands.Undo"
                                  CommandTarget="{Binding ElementName=Editor}"
                                  InputGestureText="Ctrl+Z"/>
                        <MenuItem Header="_Redo"
                                  Command="ApplicationCommands.Redo"
                                  CommandTarget="{Binding ElementName=Editor}"
                                  InputGestureText="Ctrl+Y"/>
                        <Separator/>
                        <MenuItem Header="Cu_t"
                                  Command="ApplicationCommands.Cut"
                                  CommandTarget="{Binding ElementName=Editor}"
                                  InputGestureText="Ctrl+X"/>
                        <MenuItem Header="_Copy"
                                  Command="ApplicationCommands.Copy"
                                  CommandTarget="{Binding ElementName=Editor}"
                                  InputGestureText="Ctrl+C"/>
                        <MenuItem Header="_Paste"
                                  Command="ApplicationCommands.Paste"
                                  CommandTarget="{Binding ElementName=Editor}"
                                  InputGestureText="Ctrl+V"/>
                        <MenuItem Header="_Delete"
                                  Command="ApplicationCommands.Delete"
                                  CommandTarget="{Binding ElementName=Editor}"
                                  InputGestureText="Del"/>
                        <Separator/>
                        <MenuItem Header="_Find…"
                                  Command="{Binding ShowFindCommand}"
                                  InputGestureText="Ctrl+F"/>
                        <MenuItem Header="Find _Next"
                                  Command="{Binding FindNextCommand}"
                                  InputGestureText="F3"/>
                        <MenuItem Header="Find _Previous"
                                  Command="{Binding FindPrevCommand}"
                                  InputGestureText="Shift+F3"/>
                        <MenuItem Header="_Replace…"
                                  Command="{Binding ShowReplaceCommand}"
                                  InputGestureText="Ctrl+H"/>
                        <MenuItem Header="_Go To…"
                                  Command="{Binding GoToLineCommand}"
                                  InputGestureText="Ctrl+G"/>
                        <Separator/>
                        <MenuItem Header="Select _All"
                                  Command="ApplicationCommands.SelectAll"
                                  CommandTarget="{Binding ElementName=Editor}"
                                  InputGestureText="Ctrl+A"/>
                    </MenuItem>

                </Menu>
            </DockPanel>
        </Border>

        <!-- ── Find / Replace panel ─────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{StaticResource TitleBarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,6"
                Visibility="{Binding ShowFind, Converter={StaticResource BoolToVisConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Find row -->
                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Find:"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Grid.Column="1" x:Name="SearchBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,6,0"
                             KeyDown="SearchBox_KeyDown"/>
                    <Button Grid.Column="2" Content="▲ Prev"
                            Style="{StaticResource FlatButton}"
                            Command="{Binding FindPrevCommand}"
                            Margin="0,0,4,0" Padding="8,3"/>
                    <Button Grid.Column="3" Content="▼ Next"
                            Style="{StaticResource FlatButton}"
                            Command="{Binding FindNextCommand}"
                            Margin="0,0,8,0" Padding="8,3"/>
                    <CheckBox Grid.Column="4" Content="Match case"
                              IsChecked="{Binding MatchCase}"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"/>
                    <Button Grid.Column="5" Content="✕"
                            Style="{StaticResource IconButton}"
                            Command="{Binding HideFindCommand}"
                            Padding="6,3"/>
                </Grid>

                <!-- Replace row (conditional) -->
                <Grid Grid.Row="1"
                      Visibility="{Binding ShowReplace, Converter={StaticResource BoolToVisConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Replace:"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Grid.Column="1" x:Name="ReplaceBox"
                             Text="{Binding ReplaceText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,6,0"
                             KeyDown="ReplaceBox_KeyDown"/>
                    <Button Grid.Column="2" Content="Replace"
                            Style="{StaticResource FlatButton}"
                            Command="{Binding ReplaceOneCommand}"
                            Margin="0,0,4,0" Padding="8,3"/>
                    <Button Grid.Column="3" Content="Replace All"
                            Style="{StaticResource FlatButton}"
                            Command="{Binding ReplaceAllCommand}"
                            Margin="0,0,4,0" Padding="8,3"/>
                    <Border Grid.Column="4" Width="31"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ── Main text editor (AvalonEdit) ────────────────────────────────── -->
        <avalonEdit:TextEditor
                 x:Name="Editor"
                 Grid.Row="2"
                 FontFamily="{Binding FontFamily}"
                 FontSize="{Binding FontSize}"
                 Background="#1a1a1a"
                 Foreground="#d4d4d4"
                 BorderThickness="0"
                 Padding="5,8"
                 ShowLineNumbers="True"
                 LineNumbersForeground="#555555"
                 WordWrap="{Binding WordWrap}"
                 IsReadOnly="{Binding IsReadOnly}"
                 HorizontalScrollBarVisibility="{Binding HScrollVisibility}"
                 VerticalScrollBarVisibility="Auto"/>

        <!-- ── Status bar ────────────────────────────────────────────────── -->
        <StatusBar Grid.Row="3"
                   Background="{StaticResource TitleBarBrush}"
                   BorderBrush="{StaticResource BorderBrush}"
                   BorderThickness="0,1,0,0"
                   Visibility="{Binding ShowStatusBar, Converter={StaticResource BoolToVisConverter}}">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource ForegroundDimBrush}"
                           Margin="4,0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
