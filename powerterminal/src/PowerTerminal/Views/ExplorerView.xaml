<UserControl x:Class="PowerTerminal.Views.ExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SurfaceBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Panel header -->
        <Border Grid.Row="0"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <TextBlock Text="Explorer"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{StaticResource ForegroundBrush}"/>
        </Border>

        <!-- Toolbar: path bar + navigation -->
        <Grid Grid.Row="1" Margin="6,6,6,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Content="&#x2B06;"
                    Style="{StaticResource FlatButton}"
                    Command="{Binding NavigateUpCommand}"
                    ToolTip="Go up"
                    Margin="0,0,4,0" Width="28" Height="26"/>
            <TextBox Grid.Column="1"
                     x:Name="PathBar"
                     Text="{Binding PathBarText, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsConnected}"
                     Background="{StaticResource SurfaceBrush}"
                     Foreground="{StaticResource ForegroundBrush}"
                     BorderBrush="{StaticResource BorderBrush}"
                     BorderThickness="1"
                     Padding="6,3"
                     Height="26"
                     KeyDown="PathBar_KeyDown"
                     FontFamily="Consolas" FontSize="11"/>
            <Button Grid.Column="2"
                    Content="&#x2192;"
                    Style="{StaticResource FlatButton}"
                    Command="{Binding NavigateCommand}"
                    ToolTip="Navigate"
                    Margin="4,0,4,0" Width="28" Height="26"/>
            <Button Grid.Column="3"
                    Content="&#x21BB;"
                    Style="{StaticResource FlatButton}"
                    Command="{Binding RefreshCommand}"
                    ToolTip="Refresh"
                    Width="28" Height="26"/>
        </Grid>

        <!-- Sudo toggle -->
        <CheckBox Grid.Row="2"
                  x:Name="SudoCheckBox"
                  Content="View all files (sudo)"
                  IsChecked="{Binding UseSudo, Mode=OneWay}"
                  IsEnabled="{Binding IsConnected}"
                  Foreground="{StaticResource ForegroundBrush}"
                  Margin="10,4,0,4"
                  Checked="SudoCheckBox_Checked"
                  Unchecked="SudoCheckBox_Unchecked"/>

        <!-- File list -->
        <ListView Grid.Row="3"
                  x:Name="FileList"
                  ItemsSource="{Binding Items}"
                  Background="Transparent"
                  BorderThickness="0"
                  Margin="0"
                  MouseDoubleClick="FileList_MouseDoubleClick"
                  PreviewTextInput="FileList_PreviewTextInput"
                  PreviewKeyDown="FileList_PreviewKeyDown"
                  VirtualizingStackPanel.IsVirtualizing="True">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="30">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Image Width="20" Height="20" RenderOptions.BitmapScalingMode="HighQuality" Margin="2,0,0,0">
                                    <Image.Source>
                                        <MultiBinding Converter="{StaticResource FileIconConverter}">
                                            <Binding Path="IsDirectory"/>
                                            <Binding Path="Name"/>
                                        </MultiBinding>
                                    </Image.Source>
                                </Image>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="34">
                        <GridViewColumn.Header>
                            <TextBlock Text="🔑" FontSize="11" ToolTip="Read/Write permissions"/>
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding PermissionDisplay}"
                                           FontSize="11" FontWeight="Bold"
                                           TextAlignment="Center" Width="30">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#4EC94E"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PermissionDisplay}" Value="r">
                                                    <Setter Property="Foreground" Value="#E8B44D"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PermissionDisplay}" Value="–">
                                                    <Setter Property="Foreground" Value="#CC4444"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Name" Width="170">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"
                                           FontSize="13"
                                           Foreground="{StaticResource ForegroundBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Size" Width="70">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SizeDisplay}"
                                           FontSize="12"
                                           Foreground="{StaticResource ForegroundDimBrush}"
                                           HorizontalAlignment="Right"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Modified" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Modified}"
                                           FontSize="12"
                                           Foreground="{StaticResource ForegroundDimBrush}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Disconnected overlay -->
        <StackPanel Grid.Row="3"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsDisconnected, Converter={StaticResource BoolToVisConverter}}">
            <TextBlock Text="⛔"
                       FontSize="36"
                       Foreground="{StaticResource ForegroundDimBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Connect to a server"
                       FontSize="13"
                       Foreground="{StaticResource ForegroundDimBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="to browse files"
                       FontSize="12"
                       Foreground="{StaticResource ForegroundDimBrush}"
                       HorizontalAlignment="Center"
                       Opacity="0.6"/>
        </StackPanel>

        <!-- Loading overlay -->
        <Border Grid.Row="3"
                Background="{StaticResource SurfaceBrush}"
                Opacity="0.7"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConverter}}">
            <TextBlock Text="Loading..."
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource ForegroundDimBrush}"/>
        </Border>

        <!-- Status bar -->
        <TextBlock Grid.Row="4"
                   Text="{Binding StatusMessage}"
                   Foreground="OrangeRed"
                   FontSize="11"
                   Margin="8,2,8,4"
                   TextWrapping="Wrap"
                   Visibility="{Binding StatusMessage, Converter={StaticResource NullOrEmptyToVisInvertConverter}}"/>
    </Grid>
</UserControl>

