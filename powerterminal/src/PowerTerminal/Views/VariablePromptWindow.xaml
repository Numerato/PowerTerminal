<Window x:Class="PowerTerminal.Views.VariablePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="380" SizeToContent="Height"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border BorderBrush="#777777"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource BackgroundBrush}"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource TitleBarBrush}"
                    BorderBrush="#3b3b3c"
                    BorderThickness="0,0,0,1"
                    CornerRadius="7,7,0,0">
            <Grid MouseLeftButtonDown="TitleBar_MouseDown">
                <TextBlock Text="Enter Variable"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Foreground="{StaticResource ForegroundDimBrush}"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"/>
                <Button Style="{StaticResource DialogCloseButton}"
                        HorizontalAlignment="Right"
                        Click="Cancel_Click">
                    <TextBlock Text="&#xE8BB;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="10"/>
                </Button>
            </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="16,14,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           x:Name="PromptLabel"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"/>

                <TextBox Grid.Row="1"
                         x:Name="ValueInput"
                         Margin="0,0,0,14"
                         KeyDown="ValueInput_KeyDown"/>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="OK"
                            Style="{StaticResource AccentButton}"
                            Click="OK_Click"
                            Margin="0,0,8,0" MinWidth="70"/>
                    <Button Content="Cancel"
                            Style="{StaticResource FlatButton}"
                            Click="Cancel_Click"
                            MinWidth="70"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
