<Window x:Class="PowerTerminal.Views.DarkMessageBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="400" SizeToContent="Height"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border BorderBrush="#777777"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource BackgroundBrush}"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource TitleBarBrush}"
                    BorderBrush="#3b3b3c"
                    BorderThickness="0,0,0,1"
                    CornerRadius="7,7,0,0">
                <Grid MouseLeftButtonDown="TitleBar_MouseDown">
                    <TextBlock x:Name="TitleText"
                               Text="Information"
                               FontWeight="SemiBold" FontSize="12"
                               Foreground="{StaticResource ForegroundDimBrush}"
                               VerticalAlignment="Center" Margin="14,0,0,0"/>
                    <Button Style="{StaticResource DialogCloseButton}"
                            HorizontalAlignment="Right"
                            Click="Dismiss_Click">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="20,18,20,20">

                <!-- Icon + message -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="IconText"
                               Grid.Column="0"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="22"
                               VerticalAlignment="Top"
                               Margin="0,1,12,0"
                               Visibility="Collapsed"/>
                    <TextBlock x:Name="MessageText"
                               Grid.Column="1"
                               TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="{StaticResource ForegroundBrush}"/>
                </Grid>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="YesButton"    Content="Yes"    Visibility="Collapsed"
                            Style="{StaticResource AccentButton}"
                            Click="Yes_Click"    Margin="0,0,8,0" MinWidth="72"/>
                    <Button x:Name="OkButton"     Content="OK"     Visibility="Collapsed"
                            Style="{StaticResource AccentButton}"
                            Click="Ok_Click"     Margin="0,0,8,0" MinWidth="72"/>
                    <Button x:Name="NoButton"     Content="No"     Visibility="Collapsed"
                            Style="{StaticResource FlatButton}"
                            Click="No_Click"     Margin="0,0,8,0" MinWidth="72"/>
                    <Button x:Name="CancelButton" Content="Cancel" Visibility="Collapsed"
                            Style="{StaticResource FlatButton}"
                            Click="Cancel_Click" MinWidth="72" IsCancel="True"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
