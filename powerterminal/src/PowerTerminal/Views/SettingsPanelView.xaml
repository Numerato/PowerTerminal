<UserControl x:Class="PowerTerminal.Views.SettingsPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Panel header -->
        <Border Grid.Row="0"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <TextBlock Text="Settings"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{StaticResource ForegroundBrush}"/>
        </Border>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12">
            <StackPanel>

                <!-- AI Settings -->
                <TextBlock Text="AI Configuration"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="API Base URL:"/>
                    <TextBox Grid.Column="1" x:Name="ApiBaseUrl"
                             ToolTip="OpenAI-compatible endpoint"/>
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="API Token:"/>
                    <PasswordBox Grid.Column="1" x:Name="ApiToken" PasswordChar="*"/>
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Model:"/>
                    <TextBox Grid.Column="1" x:Name="ModelName"
                             ToolTip="e.g. gpt-4o-mini, gpt-4o"/>
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Temperature:"/>
                    <Slider Grid.Column="1" x:Name="Temperature"
                            Minimum="0" Maximum="2"
                            SmallChange="0.1" LargeChange="0.5"
                            TickFrequency="0.1"
                            Foreground="{StaticResource AccentBrush}"/>
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="System Prompt:"/>
                    <TextBox Grid.Column="1" x:Name="SystemPrompt"
                             AcceptsReturn="True" MinHeight="80" MaxHeight="120"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>
                </Grid>

                <Separator Margin="0,12,0,12"/>

                <!-- SSH Settings -->
                <TextBlock Text="SSH Configuration"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="SSH Keys Folder:"/>
                    <TextBox Grid.Column="1" x:Name="SshKeysFolderInput"
                             ToolTip="Folder to search for SSH private keys"
                             Margin="0,0,4,0"/>
                    <Button Grid.Column="2" Content="Browse"
                            Style="{StaticResource FlatButton}"
                            Click="BrowseSshFolder_Click"/>
                </Grid>

                <TextBlock Text="Keys are auto-discovered by host name, known_hosts, and standard filenames."
                           Foreground="{StaticResource ForegroundDimBrush}"
                           FontSize="11" TextWrapping="Wrap"
                           Margin="130,0,0,0"/>

                <Separator Margin="0,12,0,12"/>

                <!-- Terminal Appearance -->
                <TextBlock Text="Terminal Appearance"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Font Family:"/>
                    <TextBox Grid.Column="1" x:Name="FontFamilyInput"/>
                </Grid>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Font Size:"/>
                    <TextBox Grid.Column="1" x:Name="FontSizeInput"/>
                </Grid>

                <Separator Margin="0,12,0,12"/>

                <!-- Debug -->
                <TextBlock Text="Debug Settings"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,8"/>

                <CheckBox x:Name="DebugLoggingCheck"
                          Content="Enable Debug Logging (Requires Restart)"
                          Foreground="{StaticResource ForegroundBrush}"
                          Margin="0,0,0,8"/>

                <Separator Margin="0,12,0,12"/>

                <!-- Editor Settings -->
                <TextBlock Text="Editor Settings"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,8"/>

                <CheckBox x:Name="EnablePowerEditCheck"
                          Content="Enable PowerEdit"
                          Foreground="{StaticResource ForegroundBrush}"
                          Margin="0,0,0,16"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Save button -->
        <Border Grid.Row="2"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Button Content="Save Settings"
                    Style="{StaticResource AccentButton}"
                    HorizontalAlignment="Right"
                    MinWidth="110"
                    Click="Save_Click"/>
        </Border>
    </Grid>
</UserControl>

